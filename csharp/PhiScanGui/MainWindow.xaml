<Window x:Class="PhiScanGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PhiScanGui.ViewModels"
        Title="PHI Scan — check a folder BEFORE it becomes a repo"
        Height="560" Width="900" MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Folder picker row -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="Cancel" Command="{Binding CancelCommand}"
                    Width="70" Margin="6,0,0,0" />
            <Button DockPanel.Dock="Right" Content="Scan" Command="{Binding ScanCommand}"
                    Width="90" Margin="6,0,0,0" FontWeight="Bold" />
            <Button DockPanel.Dock="Right" Content="Browse..." Command="{Binding BrowseCommand}"
                    Width="80" Margin="6,0,0,0" />
            <TextBox Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" />
        </DockPanel>

        <!-- Findings grid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Findings}"
                  SelectedItem="{Binding SelectedFinding, Mode=TwoWay}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Ignore?" Binding="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                <DataGridTextColumn Header="Severity" Binding="{Binding SeverityText}" IsReadOnly="True" Width="80" />
                <DataGridTextColumn Header="In .gitignore?" Binding="{Binding CoveredText}" IsReadOnly="True" Width="90" />
                <DataGridTextColumn Header="File / folder" Binding="{Binding RelativePath}" IsReadOnly="True" Width="300" />
                <DataGridTextColumn Header="Why it was flagged" Binding="{Binding Reason}" IsReadOnly="True" Width="*" />
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SeverityText}" Value="HIGH">
                            <Setter Property="Background" Value="#FFE0E0" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SeverityText}" Value="MEDIUM">
                            <Setter Property="Background" Value="#FFF6D8" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SeverityText}" Value="REVIEW">
                            <Setter Property="Background" Value="#E2EEFF" />
                        </DataTrigger>
                        <!-- Covered rows muted: handled, but still visible on purpose -->
                        <DataTrigger Binding="{Binding IsCovered}" Value="True">
                            <Setter Property="Background" Value="#F3F3F3" />
                            <Setter Property="Foreground" Value="#888" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- Action row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Add checked items to .gitignore" Command="{Binding AddToGitignoreCommand}"
                    Padding="10,4" FontWeight="Bold" />
            <Button Content="Open in Explorer" Command="{Binding OpenInExplorerCommand}"
                    Padding="10,4" Margin="8,0,0,0" />
            <Button Content="Copy report" Command="{Binding CopyReportCommand}"
                    Padding="10,4" Margin="8,0,0,0" />
            <TextBlock VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#666"
                       Text="Moving data OUT of the folder beats ignoring it." />
        </StackPanel>

        <!-- Status bar -->
        <Border Grid.Row="3" Margin="0,8,0,0" Padding="8,5" Background="#F2F2F2" CornerRadius="3">
            <DockPanel>
                <ProgressBar DockPanel.Dock="Right" Width="120" Height="14" IsIndeterminate="True"
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
